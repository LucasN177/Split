@using Split.Services
@inherits LayoutComponentBase
@inject AppStateService AppStateService

@* Required *@
<MudThemeProvider Theme="@_theme" IsDarkMode="@AppStateService.IsDarkMode"/>
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary" Fixed="true" Dense="false">
    <MudIconButton Icon="@Icons.Material.Filled.Menu" 
                   Color="Color.Inherit" 
                   Edge="Edge.Start" 
                   OnClick="@AppStateService.DrawerToggle" />
        
    
        <MudStack Row="false" Spacing="0">
            <MudText Typo="Typo.h5" Class="mr-6 font-weight-bold" Style="margin-bottom: 0">
                Split €
            </MudText>
			<MudHidden Breakpoint="Breakpoint.SmAndDown">
		        <MudText Typo="Typo.body2" Style="margin-top: 0">By Lucas Nagelsmann</MudText>
	        </MudHidden>
		</MudStack>
            
    <MudSpacer />
        
    <MudIconButton Icon="@(AppStateService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                   Color="Color.Inherit" 
                   OnClick="@AppStateService.ToggleDarkMode" />
    </MudAppBar>
    <MudDrawer @bind-Open="AppStateService.IsDrawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="@DrawerVariant.Responsive"
               OpenMiniOnHover="false">
        <NavMenu/>
        <MudSpacer/>
        @if (AppStateService.IsDrawerOpen)
        {
            <div class="pa-4">
                <MudDivider Class="mb-4"/>
                <MudText Color="Color.Secondary" Typo="Typo.caption" Class="text-center text-muted">
                    Split v0.1
                </MudText>
                <MudText Color="Color.Secondary" Typo="Typo.caption" Class="text-center text-muted">
                    © 2026
                </MudText>
            </div>
        }
    </MudDrawer>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code
{
    
    private readonly MudTheme _theme = new()
{
    PaletteLight = new PaletteLight()
    {
        // Hauptfarben
        Primary = "#F97316",                 // Orange 500
        PrimaryContrastText = "#ffffff",

        Secondary = "#EA580C",               // dunkleres Orange
        SecondaryContrastText = "#ffffff",

        Success = "#22C55E",
        Info = "#0EA5E9",
        Warning = "#F59E0B",
        Error = "#EF4444",

        Dark = "#1F2937",

        // Text
        TextPrimary = "#1F2937",
        TextSecondary = "#6B7280",

        // Hintergrund
        Background = "#F8FAFC",
        Surface = "#FFFFFF",

        // Drawer
        DrawerBackground = "#FFFFFF",
        DrawerText = "#374151",

        // AppBar
        AppbarBackground = "#FFFFFF",
        AppbarText = "#1F2937"
    },

    PaletteDark = new PaletteDark()
    {
        // Orange wirkt im Dark Theme etwas heller
        Primary = "#FB923C",                 // Orange 400
        PrimaryContrastText = "#1C1917",

        Secondary = "#FDBA74",               // Orange 300
        SecondaryContrastText = "#1C1917",

        Success = "#4ADE80",
        Info = "#38BDF8",
        Warning = "#FBBF24",
        Error = "#F87171",

        Dark = "#030712",

        TextPrimary = "#F3F4F6",
        TextSecondary = "#D1D5DB",

        Background = "#111827",
        Surface = "#1F2937",

        DrawerBackground = "#1F2937",
        DrawerText = "#F3F4F6",

        AppbarBackground = "#111827",
        AppbarText = "#F3F4F6"
    },

    Typography = new Typography()
    {
        Default = new DefaultTypography()
        {
            FontFamily = new[]
            {
                "Inter",
                "Roboto",
                "Helvetica",
                "Arial",
                "sans-serif"
            }
        },

        H4 = new H4Typography()
        {
            FontWeight = "700"
        },

        H5 = new H5Typography()
        {
            FontWeight = "600"
        },

        H6 = new H6Typography()
        {
            FontWeight = "600"
        }
    },

    Shadows = new Shadow(),
    ZIndex = new ZIndex()
};
    
}
